modules = ["nodejs-24"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
VITE_EMAILJS_PUBLIC_KEY = "4Y1myI5PXI0Fl44Hx"
VITE_EMAILJS_SERVICE_ID = "service_2ytzz6g"
VITE_EMAILJS_TEMPLATE_ID = "template_nc3uh7h"
